{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist/",
    "noImplicitAny": true,
    "module": "nodenext",
    "lib": ["es2020"],
    "target": "esnext",
    "jsx": "react",
    "allowJs": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/static"]
}
